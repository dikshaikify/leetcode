class Solution:
    def survivedRobotsHealths(self, positions: List[int], healths: List[int], directions: str) -> List[int]:
        n = len(positions)
        # Create an index array to keep track of original positions for the final output
        indices = list(range(n))
        # Sort indices based on the robot's physical position
        indices.sort(key=lambda x: positions[x])
        
        stack = []  # Holds indices of robots moving 'R'
        
        for i in indices:
            if directions[i] == 'R':
                stack.append(i)
            else:
                # Robot is moving 'L', check for collisions with 'R' robots in stack
                while stack and healths[i] > 0:
                    top = stack[-1]
                    
                    if healths[i] > healths[top]:
                        # Left robot wins this round
                        healths[top] = 0
                        healths[i] -= 1
                        stack.pop()
                    elif healths[i] < healths[top]:
                        # Right robot wins
                        healths[top] -= 1
                        healths[i] = 0
                    else:
                        # Both destroyed
                        healths[top] = 0
                        healths[i] = 0
                        stack.pop()
        
        # Return healths of survivors in their original input order
        return [h for h in healths if h > 0]
