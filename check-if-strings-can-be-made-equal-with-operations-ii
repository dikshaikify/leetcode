from collections import Counter

class Solution:
    def checkStrings(self, s1: str, s2: str) -> bool:
        # Check even indices
        even_s1 = Counter(s1[0::2])
        even_s2 = Counter(s2[0::2])
        
        # Check odd indices
        odd_s1 = Counter(s1[1::2])
        odd_s2 = Counter(s2[1::2])
        
        return even_s1 == even_s2 and odd_s1 == odd_s2
