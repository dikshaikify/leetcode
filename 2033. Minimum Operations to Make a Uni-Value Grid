import java.util.*;

class Solution {
    public int minOperations(int[][] grid, int x) {
        List<Integer> list = new ArrayList<>();
        
        // Flatten grid
        for (int[] row : grid) {
            for (int val : row) {
                list.add(val);
            }
        }
        
        // Check feasibility
        int base = list.get(0);
        for (int val : list) {
            if ((val - base) % x != 0) return -1;
        }
        
        // Sort
        Collections.sort(list);
        
        // Find median
        int n = list.size();
        int median = list.get(n / 2);
        
        // Calculate operations
        int operations = 0;
        for (int val : list) {
            operations += Math.abs(val - median) / x;
        }
        
        return operations;
    }
}
