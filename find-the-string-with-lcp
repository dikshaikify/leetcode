class Solution:
    def findTheString(self, lcp: List[List[int]]) -> str:
        n = len(lcp)
        res = [None] * n
        char_code = ord('a')
        
        # 1. Greedy Assignment
        for i in range(n):
            if res[i] is not None:
                continue
            if char_code > ord('z'):
                return "" # More than 26 characters needed
            
            curr_char = chr(char_code)
            for j in range(i, n):
                if lcp[i][j] > 0:
                    res[j] = curr_char
            char_code += 1
            
        # If any index wasn't filled (shouldn't happen with valid LCP)
        if None in res:
            return ""
        
        s = "".join(res)
        
        # 2. Verification using Dynamic Programming
        # We check if the constructed string generates the same LCP matrix
        actual_lcp = [[0] * (n + 1) for _ in range(n + 1)]
        for i in range(n - 1, -1, -1):
            for j in range(n - 1, -1, -1):
                if s[i] == s[j]:
                    actual_lcp[i][j] = actual_lcp[i + 1][j + 1] + 1
                else:
                    actual_lcp[i][j] = 0
                
                # Check if the generated LCP matches the input
                if actual_lcp[i][j] != lcp[i][j]:
                    return ""
                    
        return s
